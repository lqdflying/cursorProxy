{
  "redirects": [
    { "source": "/", "destination": "https://github.com/lqdflying/cursorProxy", "permanent": false }
  ],
  "rewrites": [
    { "source": "/deepseek/v1/:path*", "destination": "/api/proxy?provider=deepseek&path=:path*" },
    { "source": "/kimi/v1/:path*", "destination": "/api/proxy?provider=kimi&path=:path*" },
    { "source": "/minimax/v1/:path*", "destination": "/api/proxy?provider=minimax&path=:path*" },
    { "source": "/mimo/v1/:path*", "destination": "/api/proxy?provider=mimo&path=:path*" },
    { "source": "/glm/v1/:path*", "destination": "/api/proxy?provider=glm&path=:path*" },
    { "source": "/fireworks/v1/:path*", "destination": "/api/proxy?provider=fireworks&path=:path*" },
    { "source": "/azure-openai/v1/:path*", "destination": "/api/proxy?provider=azureopenai&path=:path*" },
    { "source": "/azure-anthropic/v1/:path*", "destination": "/api/proxy?provider=azureanthropic&path=:path*" },
    { "source": "/openaicompat/v1/:path*", "destination": "/api/proxy?provider=openaicompat&path=:path*" },
    { "source": "/anthropiccompat/v1/:path*", "destination": "/api/proxy?provider=anthropiccompat&path=:path*" },
    { "source": "/v1/:path*", "destination": "/api/proxy?path=:path*" },
    { "source": "/v0/:path*", "destination": "/api/proxy?path=:path*" }
  ]
}
