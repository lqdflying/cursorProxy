# Required: secret Cursor sends (Authorization: Bearer … or x-api-key).
# Generate e.g. `openssl rand -hex 32` — paste the output here (no newlines).
CURSORPROXY_API_KEY=sk-your-proxy-secret

# Required: upstream provider API keys (never sent to the browser)
DEEPSEEK_API_KEY=sk-xxxxxxxx
KIMI_API_KEY=sk-xxxxxxxx
MINIMAX_API_KEY=sk-xxxxxxxx
MIMO_API_KEY=sk-xxxxxxxx
GLM_API_KEY=sk-xxxxxxxx

# Fireworks AI (open-source model hosting: Kimi K2.7, DeepSeek, GLM 5.2, etc.)
# FIREWORKS_API_KEY=sk-xxxxxxxx
# Optional: force reasoning effort for Fireworks-hosted GLM 5.2 (default: max).
# Values: max, xhigh, high, medium, low, none. Overrides any client-sent value.
# Independent of GLM_REASONING_EFFORT (which only affects the native GLM provider).
# FIREWORKS_GLM_REASONING_EFFORT=max

# ─── Azure AI Foundry ────────────────────────────────────────────────────────
# Required for Azure model IDs (e.g., gpt-5.5, claude-sonnet-4-6).
# Configure CURSORPROXY_MODELS with bare IDs; discovery returns cursorproxy/<id>.
# AZURE_FOUNDRY_API_KEY=xxxxxxxx
# AZURE_FOUNDRY_RESOURCE=quand-mos8to0k-eastus2
# AZURE_OPENAI_API_VERSION=2025-04-01-preview  # Azure OpenAI Responses API version
# AZURE_OPENAI_ENDPOINT=https://xxx.cognitiveservices.azure.com  # optional: override full base URL
# AZURE_ANTHROPIC_ENDPOINT=https://xxx.services.ai.azure.com  # optional: override full base URL
# AZURE_OPENAI_REASONING_EFFORT=high  # optional: force effort; none, minimal, low, medium, high, xhigh (model support varies)
# AZURE_ANTHROPIC_THINKING=adaptive  # optional: adaptive, disabled
# AZURE_ANTHROPIC_EFFORT=max         # optional: low, medium, high, max
#
# Public alias `cursorproxy/gpt-general` → real Azure OpenAI deployment.
# When set, requests for `gpt-general` are rewritten in-flight to the deployment
# below; the response.model field stays as `cursorproxy/gpt-general` so clients
# see the alias they asked for. Add `gpt-general` to CURSORPROXY_MODELS to expose
# it in /v1/models discovery.
# AZURE_OPENAI_GENERAL_ALIAS_TARGET=gpt-5.5-mini   # actual Azure deployment for gpt-general
# AZURE_OPENAI_GENERAL_REASONING_EFFORT=medium     # optional: alias-only override of effort
                                                   # (precedence: alias > AZURE_OPENAI_REASONING_EFFORT > client)

# Optional: bare model IDs exposed by GET /v1/models as cursorproxy/<id>.
# Supports comma- or newline-separated values; duplicates are ignored.
# CURSORPROXY_MODELS=deepseek-v4-pro,kimi-k2.7-code,MiniMax-M3,mimo-v2.5-pro,GLM-5.2,claude-sonnet-4-6,gpt-5.5

# Optional: override upstream base URLs
# UPSTREAM_DEEPSEEK=https://api.deepseek.com
# UPSTREAM_KIMI=https://api.moonshot.ai
# UPSTREAM_MINIMAX=https://api.minimax.io
# UPSTREAM_MIMO=https://api.xiaomimimo.com
# GLM defaults to the ZHIPU China Coding Plan endpoint:
# UPSTREAM_GLM=https://open.bigmodel.cn/api/coding/paas/v4
# For the global Z.AI Coding Plan endpoint, set:
# UPSTREAM_GLM=https://api.z.ai/api/coding/paas/v4
# UPSTREAM_FIREWORKS=https://api.fireworks.ai/inference

# ─── OpenAI-Compatible Generic Provider ──────────────────────────────────────
# Point at any endpoint speaking the OpenAI Chat Completions API (e.g.
# Together AI, Groq, OpenRouter, self-hosted vLLM).
# Use model aliases: compatible-gpt-5.6 → sends gpt-5.6-sol upstream.
# gpt-5.6 is OpenAI's alias for the flagship GPT-5.6 Sol model.
# OPENAICOMPAT_API_KEY=sk-xxxxxxxx
# UPSTREAM_OPENAICOMPAT=https://api.openai.com
# OPENAICOMPAT_DEFAULT_MODEL=gpt-5.6-sol       # injected when client omits model
# OPENAICOMPAT_REASONING_CACHE=true             # opt-in: enable reasoning bridge caching (chat mode only)
# OPENAICOMPAT_WIRE_API=chat                    # chat (default) | responses
#                                             # This is the switch: chat activates
#                                             # OPENAICOMPAT_CHAT_CACHE_MODE; responses
#                                             # activates OPENAICOMPAT_CACHE_HIT_MODE.
# OPENAICOMPAT_CHAT_CACHE_MODE=passthrough      # passthrough | facade | remote. Chat mode only;
#                                             # facade normalizes raw Chat cache-hit usage
#                                             # and forces upstream stream usage chunks;
#                                             # remote also injects prompt_cache_key and
#                                             # forwards a matching Session_id header so
#                                             # the upstream owns state/cache mapping.
#                                             # For api.apikl.ai-style gateways confirmed
#                                             # by provider logs, prefer:
#                                             # OPENAICOMPAT_WIRE_API=chat
#                                             # OPENAICOMPAT_CHAT_CACHE_MODE=remote
# OPENAICOMPAT_CACHE_HIT_MODE=default           # default | sub2api | halo | passion8. Responses only;
#                                             # default uses store:true, previous_response_id,
#                                             # and the default tool-result fallback.
#                                             # sub2api adds GPT-5/Codex prompt_cache_key
#                                             # injection, session anchors, stale previous
#                                             # response cleanup, and unsupported-scope TTLs.
#                                             # halo and passion8 share halo_* prompt_cache_key
#                                             # derivation, Session_id forwarding, the "halo"
#                                             # oairesp scope, stateless-first tool output, and
#                                             # ordinary tool done-argument repair.
#                                             # halo also repairs the nested CallMcpTool schema;
#                                             # passion8 preserves the vendor's working schema.
#                                             # Use passion8 only to preserve pre-2111555 Halo
#                                             # behavior; use halo when nested MCP repair is needed.
#                                             # Both inject/preserve prompt_cache_key and
#                                             # forward/derive Session_id for gateways where
#                                             # Responses cache hits need prompt_cache_key +
#                                             # Session_id + store:true.
#                                             # Invalid values return a 400 in Responses mode.
# OPENAICOMPAT_REASONING_EFFORT=max             # chat + responses; none, minimal,
#                                             # low, medium, high, xhigh, max. Overrides
#                                             # client effort. Chat forwards flat
#                                             # reasoning_effort; responses forwards
#                                             # nested reasoning.effort. In Responses mode,
#                                             # GPT-5.6 Sol supports max as its highest single-
#                                             # model effort for quality-first workloads. GPT-5.5
#                                             # does not support max, so max is forwarded as xhigh
#                                             # for GPT-5.5 requests. `ultra` is multi-agent
#                                             # orchestration, not an allowed effort value; support
#                                             # varies by model/upstream, so expect higher
#                                             # cost/latency and possible rejection.
#                                             # responses: route to upstream /v1/responses and enable
#                                             # codex-style previous_response_id chaining via KV.
#                                             # Requires a KV backend. store=true forced for
#                                             # conversation-shaped requests; explicit store:false
#                                             # honored as privacy opt-out. Invalid value logs a
#                                             # one-time warning (OPENAICOMPAT_WIRE_API_INVALID)
#                                             # and falls back to chat.

# ─── Anthropic-Compatible Generic Provider ───────────────────────────────────
# Point at any endpoint speaking the Anthropic Messages API.
# Use model aliases: compatible-claude-sonnet-4-6 → sends claude-sonnet-4-6 upstream.
# ANTHROPICCOMPAT_API_KEY=sk-xxxxxxxx
# UPSTREAM_ANTHROPICCOMPAT=https://api.anthropic.com
# Auth mode: "api-key" (default, sends x-api-key header) or "bearer" (sends Authorization: Bearer).
# ANTHROPICCOMPAT_AUTH_MODE=api-key
# ANTHROPICCOMPAT_DEFAULT_MODEL=claude-sonnet-4-6  # injected when client omits model
# ANTHROPICCOMPAT_THINKING_CACHE=true               # opt-in: enable Claude thinking block caching

# KV: use REDIS_URL (Docker), KV_URL + KV_TOKEN (Vercel / Upstash), or EdgeOne Pages KV.
#      Docker Compose should use env_file: .env — do not put secrets in compose YAML.
# REDIS_URL=redis://redis:6379
# KV_URL=https://xxxx.upstash.io
# KV_TOKEN=xxxxxxxx
#
# EdgeOne Pages KV: create a KV namespace in the console, bind it to the project
# with a variable name (default: cursorproxy_kv). Override the name here if needed.
# EDGEONE_KV_BINDING=cursorproxy_kv

# ─── Image-to-Text Bridge (Vision) ─────────────────────────────────────────
# Converts screenshots/images in Cursor chat to text before forwarding to
# text-only models (DeepSeek, MiniMax, MiMo Pro/Flash/TTS). Uses MiniMax VL-01 by default
# (same API key as MINIMAX_API_KEY).
#
# Provider: "minimax_vl" (default) or "openai"
# VISION_API_PROVIDER=minimax_vl
# VISION_API_URL=https://api.minimax.io/v1/coding_plan/vlm
# VISION_MODEL=MiniMax-VL-01
#
# For OpenAI Vision:
# VISION_API_PROVIDER=openai
# VISION_API_URL=https://api.openai.com/v1/chat/completions
# VISION_MODEL=gpt-4o-mini
# VISION_API_KEY=sk-xxx
#
# Per-image vision call timeout in ms. Default 15000 (15s). On Vercel the
# function is killed at 25s if no initial Response is returned, so a stuck
# vision call would hang the whole request — this caps it. Failed images
# become a placeholder; siblings still succeed. Set to 0 to disable
# (recommended only on Docker, where there is no platform wall-clock).
# VISION_TIMEOUT_MS=15000
#
# Maximum parallel vision API calls per request. Default 2. Lower if the
# vision endpoint rate-limits on bursts; raise if your quota allows.
# VISION_CONCURRENCY=2

# ─── Tuning (optional) ─────────────────────────────────────────────────────
# DeepSeek reasoning effort: "high" (default) or "max" (longer thinking).
# Omit or leave commented for default "high". Do NOT wrap the value in quotes.
# DEEPSEEK_REASONING_EFFORT=max
#
# GLM-5.2+ reasoning effort: "max" (default), "xhigh", "high", "medium",
# "low", "minimal", or "none". Only GLM-5.2+ accepts this parameter; older
# GLM models have it stripped automatically. Overrides any client-sent value.
# GLM_REASONING_EFFORT=high
#
# KV cache TTL for conversation-scoped entries (reasoning, Azure response IDs,
# Claude thinking blocks). Seconds; default 7200 = 2h.
# KV_TTL_SECONDS=7200
#
# KV cache TTL for image-description cache (img:* keys). Images are content-
# addressed by SHA-256 of the data URI, so the description is effectively
# immutable; a longer TTL avoids re-paying the vision-API cost. Default: 7 days.
# KV_IMAGE_TTL_SECONDS=604800
#
# KV REST fetch timeout in ms. Defaults to UPSTREAM_CONNECT_TIMEOUT_MS, or 8000
# if neither is set. Caps the wait on a stalled Upstash region so the platform
# pre-stream budget isn't eaten by a hung cache read. Set to 0 to disable.
# KV_FETCH_TIMEOUT_MS=8000
#
# Wait schedule (ms, comma-separated) for the next-turn reasoning cache lookup.
# Total wait = sum of values. Default: 40,120,240,400 (= 800ms).
# KV_RETRY_DELAYS_MS=40,120,240,400
#
# Upstream connect-phase timeout in ms (cleared once headers arrive — does NOT
# abort streaming bodies). Default 15000. Set to 0 to disable entirely.
# UPSTREAM_CONNECT_TIMEOUT_MS=15000
#
# Streaming wall-clock cap (seconds). Default: 280 on Vercel, 110 on EdgeOne
# Cloud Functions (under the 120s maxDuration), and 0 (disabled) on Docker.
# Use to fail fast if upstream stalls mid-stream.
# STREAM_TIMEOUT_SECONDS=280
#
# Pre-stream budget (ms, Vercel-only). If reasoning-injection + vision
# conversion take longer than this, return a clean 504 prestream_timeout
# instead of being killed by the platform at ~25s. Ignored on Docker.
# PRESTREAM_BUDGET_MS=22000
#
# Per-stream soft caps (characters) for the proxy-side string accumulators
# used for logging and size checks. SSE chunks forwarded to the client are
# never truncated — only the in-memory copies are bounded. Defaults are
# generous; lower if you're running tight on per-instance memory.
# ACC_CONTENT_CAP_CHARS=4000000
# ACC_REASONING_CAP_CHARS=8000000
#
# Graceful shutdown deadline on Docker (ms). Default 25000. After SIGTERM /
# SIGINT, in-flight requests drain up to this long before the process exits.
# SHUTDOWN_GRACE_MS=25000

# ─── Debug & Logging ─────────────────────────────────────────────────────────
# Set to "true" to enable verbose request/response logs (proxy.js + server.js
# access log). In production, keep this commented to reduce log volume.
# EdgeOne Pages Cloud Functions support KV bindings and Log Analysis visibility.
# All EdgeOne API entry points live under cloud-functions/ for both features.
# When enabled, Docker log rotation (configured in docker-compose.yml) caps
# stdout/stderr at 10 MiB × 3 files per container to prevent disk exhaustion.
# DEBUG=true
PORT=3000
