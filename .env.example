# Required: secret Cursor sends (Authorization: Bearer … or x-api-key).
# Generate e.g. `openssl rand -hex 32` — paste the output here (no newlines).
CURSORPROXY_API_KEY=sk-your-proxy-secret

# Required: upstream provider API keys (never sent to the browser)
DEEPSEEK_API_KEY=sk-xxxxxxxx
KIMI_API_KEY=sk-xxxxxxxx
MINIMAX_API_KEY=sk-xxxxxxxx

# Optional: model IDs exposed by GET /v1/models for client discovery
# Supports comma- or newline-separated values; duplicates are ignored.
# CURSORPROXY_MODELS=deepseek-v4-pro,kimi-k2.6,MiniMax-M2.7

# Optional: override upstream base URLs
# UPSTREAM_DEEPSEEK=https://api.deepseek.com
# UPSTREAM_KIMI=https://api.moonshot.ai
# UPSTREAM_MINIMAX=https://api.minimax.io

# KV: use REDIS_URL (Docker), KV_URL + KV_TOKEN (Vercel / Upstash), or EdgeOne Pages KV.
#      Docker Compose should use env_file: .env — do not put secrets in compose YAML.
# REDIS_URL=redis://redis:6379
# KV_URL=https://xxxx.upstash.io
# KV_TOKEN=xxxxxxxx
#
# EdgeOne Pages KV: create a KV namespace in the console, bind it to the project
# with a variable name (default: cursorproxy_kv). Override the name here if needed.
# EDGEONE_KV_BINDING=cursorproxy_kv

# ─── Image-to-Text Bridge (Vision) ─────────────────────────────────────────
# Converts screenshots/images in Cursor chat to text before forwarding to
# text-only models (DeepSeek, MiniMax). Uses MiniMax VL-01 by default
# (same API key as MINIMAX_API_KEY).
#
# Provider: "minimax_vl" (default) or "openai"
# VISION_API_PROVIDER=minimax_vl
# VISION_API_URL=https://api.minimax.io/v1/coding_plan/vlm
# VISION_MODEL=MiniMax-VL-01
#
# For OpenAI Vision:
# VISION_API_PROVIDER=openai
# VISION_API_URL=https://api.openai.com/v1/chat/completions
# VISION_MODEL=gpt-4o-mini
# VISION_API_KEY=sk-xxx
#
# Per-image vision call timeout in ms. Default 15000 (15s). On Vercel the
# function is killed at 25s if no initial Response is returned, so a stuck
# vision call would hang the whole request — this caps it. Failed images
# become a placeholder; siblings still succeed. Set to 0 to disable
# (recommended only on Docker, where there is no platform wall-clock).
# VISION_TIMEOUT_MS=15000
#
# Maximum parallel vision API calls per request. Default 2. Lower if the
# vision endpoint rate-limits on bursts; raise if your quota allows.
# VISION_CONCURRENCY=2

# ─── Tuning (optional) ─────────────────────────────────────────────────────
# KV cache TTL for reasoning + vision results (seconds; default 7200 = 2h).
# KV_TTL_SECONDS=7200
#
# Wait schedule (ms, comma-separated) for the next-turn reasoning cache lookup.
# Total wait = sum of values. Default: 40,120,240,400 (= 800ms).
# KV_RETRY_DELAYS_MS=40,120,240,400
#
# Upstream connect-phase timeout in ms (cleared once headers arrive — does NOT
# abort streaming bodies). Default 15000. Set to 0 to disable entirely.
# UPSTREAM_CONNECT_TIMEOUT_MS=15000
#
# Streaming wall-clock cap (seconds). Default: 280 on Vercel, 0 (disabled) on
# Docker. Use to fail fast if upstream stalls mid-stream.
# STREAM_TIMEOUT_SECONDS=280
#
# Pre-stream budget (ms, Vercel-only). If reasoning-injection + vision
# conversion take longer than this, return a clean 504 prestream_timeout
# instead of being killed by the platform at ~25s. Ignored on Docker.
# PRESTREAM_BUDGET_MS=22000
#
# Graceful shutdown deadline on Docker (ms). Default 25000. After SIGTERM /
# SIGINT, in-flight requests drain up to this long before the process exits.
# SHUTDOWN_GRACE_MS=25000

# ─── Debug & Logging (Docker) ────────────────────────────────────────────────
# Set to "true" to enable verbose request/response logs (proxy.js + server.js
# access log). In production, keep this commented to reduce log volume.
# When enabled, Docker log rotation (configured in docker-compose.yml) caps
# stdout/stderr at 10 MiB × 3 files per container to prevent disk exhaustion.
# DEBUG=true
PORT=3000
